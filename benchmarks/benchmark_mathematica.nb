                RowBox[{"Flatten", "[", "U", "]"}], ",", 
                RowBox[{"_", "?", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"#", "=!=", "0"}], "&"}], ")"}]}]}], "]"}]}]}], ";",
             "\[IndentingNewLine]", 
            RowBox[{"LUlen", "=", 
