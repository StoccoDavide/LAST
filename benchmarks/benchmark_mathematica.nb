Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"timeLimit", "=", "7200"}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"fname", "=", 
   RowBox[{
    RowBox[{"NotebookDirectory", "[", "]"}], 
    "<>", "\"\<mathematica.csv\>\""}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"FileExistsQ", "[", "fname", "]"}], ",", 
     RowBox[{"DeleteFile", "[", "fname", "]"}]}], "]"}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"stream", "=", 
    RowBox[{"OpenAppend", "[", "fname", "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"WriteString", "[", 
    RowBox[{
    "stream", 
     ",", "\"\<size,density,type,factime,rank,Alen,LUlen,Ands,LUnds,Annz,\
LUnnz,Vnum,Vnds,Vlen\\n\>\""}], "]"}], ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", "Settings", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"testTmp", "=", 
    RowBox[{"{", 
     RowBox[{"\"\<real\>\"", ",", "\"\<symbol\>\"", ",", "\"\<poly1\>\"", 
      ",", "\"\<poly2\>\""}], "}"}]}], ";"}], " "}], "\n", 
 RowBox[{
  RowBox[{"sizeTmp", "=", 
   RowBox[{"{", 
    RowBox[{"10", ",", "25", ",", "50"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"densTmp", "=", 
    RowBox[{"{", 
     RowBox[{"100", ",", "50", ",", "25"}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"totalTests", "=", 
   RowBox[{
    RowBox[{"Length", "[", "testTmp", "]"}], "*", 
    RowBox[{"Length", "[", "sizeTmp", "]"}], "*", 
    RowBox[{"Length", "[", "densTmp", "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Total number of tests = \>\"", ",", "totalTests"}], "]"}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Print", "[", "\"\<Benchmarking the algorithms...\>\"", "]"}], 
   ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"testNum", "=", "0"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Do", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"testNum", "++"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<  test = \>\"", ",", "testNum", ",", "\"\<, entry = \>\"",
         ",", "t", ",", "\"\<, size = \>\"", ",", "n", 
        ",", "\"\<, density = \>\"", ",", "d"}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"A", "=", 
       RowBox[{"ToExpression", "[", 
        RowBox[{"\"\<A\>\"", "<>", 
         RowBox[{"ToString", "[", "n", "]"}], "<>", 
         RowBox[{"ToString", "[", "d", "]"}], "<>", "t"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Ands", "=", 
       RowBox[{"LeafCount", "[", "A", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Annz", "=", 
       RowBox[{"Count", "[", 
        RowBox[{
         RowBox[{"Flatten", "[", "A", "]"}], ",", 
         RowBox[{"_", "?", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"#", "=!=", "0"}], "&"}], ")"}]}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Alen", "=", 
       RowBox[{"StringLength", "@", 
        RowBox[{"StringReplace", "[", 
         RowBox[{
          RowBox[{"ToString", "[", 
           RowBox[{
            RowBox[{"Compress", "[", "A", "]"}], ",", "InputForm"}], "]"}], ",",
           " ", 
          RowBox[{"Whitespace", "->", "\"\<\>\""}]}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Check", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"facTime", ",", "lu"}], "}"}], "=", 
          RowBox[{"AbsoluteTiming", "[", 
           RowBox[{"TimeConstrained", "[", 
            RowBox[{
             RowBox[{"LUDecomposition", "[", "A", "]"}], ",", "timeLimit", ",",
              "$Failed"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"lu", "===", "$Failed"}], ",", "\[IndentingNewLine]", 
           RowBox[{"(*", 
            RowBox[{"Time", " ", "expired"}], "*)"}], "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"LUnds", "=", 
             RowBox[{"-", "2"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"LUnnz", "=", 
             RowBox[{"-", "2"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"LUlen", "=", 
             RowBox[{"-", "2"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"rnk", "=", 
             RowBox[{"MatrixRank", "[", "A", "]"}]}], ";"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"L", "=", 
             RowBox[{"LowerTriangularize", "[", 
              RowBox[{
               RowBox[{"lu", "[", 
                RowBox[{"[", "1", "]"}], "]"}], ",", 
               RowBox[{"-", "1"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"U", "=", 
             RowBox[{"UpperTriangularize", "[", 
              RowBox[{"lu", "[", 
               RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"rnk", "=", 
             RowBox[{"MatrixRank", "[", "A", "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"LUnds", "=", 
             RowBox[{
              RowBox[{"LeafCount", "[", "L", "]"}], "+", 
              RowBox[{"LeafCount", "[", "U", "]"}]}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"LUnnz", "=", 
             RowBox[{
              RowBox[{"Count", "[", 
               RowBox[{
                RowBox[{"Flatten", "[", "L", "]"}], ",", 
                RowBox[{"_", "?", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"#", "=!=", "0"}], "&"}], ")"}]}]}], "]"}], "+", 
              " ", 
              RowBox[{"Count", "[", 
